{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:3000/"
      ],
      "startServerCommand": "npm run start -- --hostname 127.0.0.1 --port 3000",
      "startServerReadyPattern": "Ready",
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--headless=new --incognito --disable-extensions"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.85
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 3000
          }
        ],
        "total-blocking-time": [
          "error",
          {
            "maxNumericValue": 200
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
